{
	"name": "zevbot",
	"license": "MIT",
	"author": "Zevlion",
	"type": "module",
	"devDependencies": {
		"@types/bun": "latest",
		"oxfmt": "^0.51.0",
		"oxlint": "^1.66.0",
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"audio-decode": "^3.10.1",
		"music-metadata": "^11.12.3",
		"sharp": "^0.34.5",
		"whatsapp-rust-bridge": "0.6.0-alpha.28"
	},
	"exports": {
		".": "./dist/src/index.js"
	},
	"scripts": {
		"build": "bun build ./web.mts --outdir ./dist --target bun --external whatsapp-rust-bridge --external audio-decode --external music-metadata --external sharp",
		"cli": "rpm2 start cli.mts --interpreter bun --name zevBot --watch --attach --force",
		"web": "rpm2 start dist/web.js --interpreter bun --name zevBot --watch --attach --force",
		"fmt": "oxfmt src cli.mts web.mts && tsc && oxlint --fix"
	}
}
